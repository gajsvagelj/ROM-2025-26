Cell[TextData[{
 "a)  Definirajte funkcijo A(m,n), ki sprejme naravni \[SHacek]tevili ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c9bb0f3f-389e-4071-84ad-3bcae3073717"],
 " in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["m", "TI"], TraditionalForm], "errors" -> {}, "input" -> "m", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5b804134-69c6-4d7c-bb3d-154f66954d51"],
 " in vrne matriko dimenzije ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[Cross]", 
         StyleBox["m", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "n \\times m", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1d5d1ee7-abd7-4d32-9f05-1116527722eb"],
 ", kjer se na vsakem mestu v matriki pojavi vsota indeksa stolpca in indeksa \
vrstice.\nb) Izra\[CHacek]unajte determinanto, rang in lastne vrednosti \
matrike ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["A", "TI"], "(", 
         RowBox[{"3", ",", "3"}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "A(3, 3)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c58b92c-9bc0-4cb8-b601-e6a22e3f640d"],
 ". Kaj opazite?\nc)  Nari\[SHacek]ite vektorje, ki ustrezajo stolpcem \
matrike ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["A", "TI"], "(", 
         RowBox[{"3", ",", "3"}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "A(3,3)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "90c92ed0-9b3d-4052-81ad-cf5c4dabe9a2"],
 ". S pomo\[CHacek]jo ukaza InfinitePlane na sliko nari\[SHacek]ite \
\[SHacek]e ravnino, v kateri ti trije vektorji le\[ZHacek]ijo. \nd) Dolo\
\[CHacek]ite parametra, s katerima lahko prvi stolpec matrike A(3,3) izrazimo \
z drugima dvema.\ne) Dolo\[CHacek]ite cela \[SHacek]tevila \[Alpha], ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "1"], ",", 
    RowBox[{
     SubscriptBox["x", "2"], " ", "in", " ", 
     SubscriptBox["x", "3"]}]}], TraditionalForm]],ExpressionUUID->
  "7d0daf53-fef4-46e9-bf0a-16be7759fbcc"],
 ", ki zado\[SHacek]\[CHacek]ajo enakosti \n\t\tM",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["x", "1"]},
       {
        RowBox[{
         SubscriptBox["x", "2"], "\[IndentingNewLine]", 
         SubscriptBox["x", "3"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "2b40cd7e-72b1-41b3-8a93-861b8aaa4aa7"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       RowBox[{"-", "3"}]},
      {
       RowBox[{
        RowBox[{"-", "5"}], "\[IndentingNewLine]", 
        RowBox[{"-", "9"}], "\[IndentingNewLine]", 
        RowBox[{"-", "11"}]}]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "d0243388-db53-43c8-84fa-a187b499f496"],
 " ,\n    kjer je M matrika, podana kot A(4,3)+\[Alpha]",
 StyleBox["I",
  FontSlant->"Italic"],
 ", kjer ",
 StyleBox["I",
  FontSlant->"Italic"],
 " ozna\[CHacek]uje identi\[CHacek]no matriko ustrezne velikosti. \
Re\[SHacek]itev zapi\[SHacek]ite v eni vrstici."
}], "Text",
 CellChangeTimes->{{3.955982800439632*^9, 3.955982803225081*^9}, {
   3.955982876121233*^9, 3.955982880824264*^9}, {3.987748964782*^9, 
