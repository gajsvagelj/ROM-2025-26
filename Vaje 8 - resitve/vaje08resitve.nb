Cell[TextData[{
 StyleBox["1. b)",
  FontWeight->"Bold"],
 " Z ukazom \[OpenCurlyQuote]Import\[CloseCurlyQuote] uvozi tabelo iz \
datoteke \[OpenCurlyQuote]rezultati.xlsx\[CloseCurlyQuote], v kateri se \
nahajajo rezultati pisnega izpita pri nekem predmetu. Podatke uvozi v formatu \
\[OpenCurlyQuote]Dataset\[CloseCurlyQuote]. Uvo\[ZHacek]ena tabela naj ima \
ozna\[CHacek]eno \[OpenCurlyDoubleQuote]glavo\[CloseCurlyDoubleQuote] (prvo \
vrstico - ukaz \[OpenCurlyQuote]HeaderLines\[CloseCurlyQuote]).  Tabelo shani \
v spremenljivko \[OpenCurlyQuote]podatki\[CloseCurlyQuote]. "
}], "Text",
 CellChangeTimes->{{3.9851476442378054`*^9, 3.9851476891133275`*^9}, {
  3.9851477986226935`*^9, 3.9851478720802083`*^9}, {3.985147911533061*^9, 
  3.985147926427441*^9}, {3.9852395800786467`*^9, 3.98523959301991*^9}, {
  3.9852727643812523`*^9, 
  3.9852727645569277`*^9}},ExpressionUUID->"001f8992-6442-47d6-b136-\
4b4c04781fd0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"podatki", "=", 
