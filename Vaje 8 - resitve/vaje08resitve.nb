Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Vrne", " ", "seznam", " ", "imen", " ", "stolpcev"}], 
   "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"Imena", "[", "podatki_", "]"}], ":=", 
    RowBox[{"Normal", "[", 
     RowBox[{"Keys", "[", 
      RowBox[{"podatki", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Vrne", " ", "tabelo", " ", "podatkov", " ", "brez", " ", 
     "glave"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Podatki", "[", "podatki_", "]"}], ":=", 
    RowBox[{"Normal", "[", 
     RowBox[{"Values", "[", "podatki", "]"}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Vrne", " ", "indeks", " ", "dolo\[CHacek]enega", " ", 
     "stolpca"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"IndeksStolpca", "[", 
     RowBox[{"podatki_", ",", "stolpec_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "pos", "}"}], ",", 
      RowBox[{
       RowBox[{"pos", "=", 
        RowBox[{"Position", "[", 
         RowBox[{
          RowBox[{"Imena", "[", "podatki", "]"}], ",", "stolpec"}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"pos", "===", 
          RowBox[{"{", "}"}]}], ",", "Null", ",", 
         RowBox[{"pos", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "4.", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Stolpec", "[", 
     RowBox[{"podatki_", ",", "stolpec_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"Podatki", "[", "podatki", "]"}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"IndeksStolpca", "[", 
       RowBox[{"podatki", ",", "stolpec"}], "]"}], "]"}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", "5.", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PovprecjeTock", "[", "podatki_", "]"}], ":=", 
    RowBox[{"Mean", "[", 
     RowBox[{"Stolpec", "[", 
      RowBox[{"podatki", ",", "\"\<Tocke\>\""}], "]"}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "6.", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RazlicneVrednosti", "[", 
     RowBox[{"podatki_", ",", "stolpec_"}], "]"}], ":=", 
    RowBox[{"Union", "[", 
     RowBox[{"Stolpec", "[", 
      RowBox[{"podatki", ",", "stolpec"}], "]"}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "7.", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Vrstica", "[", 
     RowBox[{"podatki_", ",", "i_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Podatki", "[", "podatki", "]"}], "[", 
     RowBox[{"[", "i", "]"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9887848825696964`*^9, 3.9887848825696964`*^9}, {
  3.9887856668832283`*^9, 
  3.9887856950651684`*^9}},ExpressionUUID->"5d2e160e-66fa-544e-aa4d-\
8f64413de0f2"],

Cell[TextData[{
 StyleBox["3.",
  FontWeight->"Bold"],
 " Sestavi funkcijo ",
 StyleBox["OcenaZaMeje[{za6_, za7_, za8_, za9_, za10_}, tocke_]",
  FontWeight->"Bold"],
 ", pri kateri so v prvem argumentu meje za ocene v \[SHacek]tevilu to\
\[CHacek]k, v drugem argumentu pa \[SHacek]tevilo to\[CHacek]k, za katere\n\
\[ZHacek]elimo izra\[CHacek]unati oceno. Funkcijo napi\[SHacek]i s pomo\
\[CHacek]jo ustreznih stavkov \[OpenCurlyQuote]",
 "If\[CloseCurlyQuote]",
 ". Nato sestavi funkcijo ",
 StyleBox["Ocene[podatki_, meje_]",
  FontWeight->"Bold"],
 ", ki izra\[CHacek]una stolpec ocen za dane podatke in meje."
}], "Text",
 CellChangeTimes->{{3.985239644692469*^9, 
  3.985239784122751*^9}},ExpressionUUID->"fa46e67f-a2c0-400c-9e56-\
76011006aee7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Funkcija", " ", "za", " ", "dolo\[CHacek]itev", " ", "ocene", " ", "na", 
    " ", "podlagi", " ", "to\[CHacek]k", " ", "in", " ", "meja"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"OcenaZaMeje", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"za6_", ",", "za7_", ",", "za8_", ",", "za9_", ",", "za10_"}], 
       "}"}], ",", "tocke_"}], "]"}], ":=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"tocke", "<", "za6"}], ",", "5", ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"tocke", "<", "za7"}], ",", "6", ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"tocke", "<", "za8"}], ",", "7", ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"tocke", "<", "za9"}], ",", "8", ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"tocke", "<", "za10"}], ",", "9", ",", "10"}], "]"}]}], 
           "]"}]}], "]"}]}], "]"}]}], "]"}]}], "\n", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Ocene", "[", 
     RowBox[{"podatki_", ",", "meje_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"OcenaZaMeje", "[", 
       RowBox[{"meje", ",", "#"}], "]"}], "&"}], "/@", 
     RowBox[{"Stolpec", "[", 
      RowBox[{"podatki", ",", "\"\<Tocke\>\""}], "]"}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.9887848961304264`*^9, 3.9887848961304264`*^9}, 
   3.9887856612628613`*^9},ExpressionUUID->"b41844d5-e76c-cb40-a895-\
6881f96275c7"],

Cell[TextData[{
 StyleBox["4.",
  FontWeight->"Bold"],
 " Sestavi funkcijo ",
 StyleBox["DodajStolpec[podatki_]",
  FontWeight->"Bold"],
 ", ki obstoje\[CHacek]i tabeli doda \[SHacek]e en stolpec (oz . vrne novo \
tabelo z dodanim stolpcem) . Premisli, kako s pomo\[CHacek]jo \
\[OpenCurlyQuote]Query\[CloseCurlyQuote] doda\[SHacek] stolpec tabeli.  \
Podatkom dodaj stolpec \"Ocena\" z ocenami in vse skupaj shrani v \
spremenljivko ",
 StyleBox["podatkiOcene",
  FontSlant->"Italic"],
 ". Novo tabelo shrani v Excelov zvezek \[OpenCurlyQuote]ocene.xlsx\
\[CloseCurlyQuote] s pomo\[CHacek]jo ukaza \[OpenCurlyQuote]Export\
\[CloseCurlyQuote] ."
}], "Text",
 CellChangeTimes->{{3.9852397776051655`*^9, 3.9852397800421305`*^9}, {
  3.9852398126988883`*^9, 3.9852399085416565`*^9}, {3.985274011227133*^9, 
  3.985274014265061*^9}, {3.9852745439486957`*^9, 
  3.9852745447927713`*^9}},ExpressionUUID->"ddafbd4d-e66d-4101-964e-\
c054ea633987"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"mejeZaOcene", "=", 
    RowBox[{"{", 
     RowBox[{"50", ",", "60", ",", "70", ",", "80", ",", "90"}], "}"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"DodajStolpec", "[", "podatki_", "]"}], ":=", 
   RowBox[{"podatki", "[", 
    RowBox[{"All", ",", 
     RowBox[{
      RowBox[{"Append", "[", 
       RowBox[{"#", ",", 
        RowBox[{"\"\<Ocena\>\"", "->", 
         RowBox[{"OcenaZaMeje", "[", 
          RowBox[{"mejeZaOcene", ",", "#Tocke"}], "]"}]}]}], "]"}], "&"}]}], 
    "]"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"podatkiOcene", "=", 
   RowBox[{"DodajStolpec", "[", "podatki", "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<ocene.xlsx\>\"", ",", "podatkiOcene"}], "]"}]}], "Input",
