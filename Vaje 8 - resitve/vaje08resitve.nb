Cell[TextData[{
 StyleBox["1. a)",
  FontWeight->"Bold"],
 " Z ukazom \[OpenCurlyQuote]Directory\[CloseCurlyQuote] preveri delovno \
podro\[CHacek]je. Nato z uporabo \[OpenCurlyQuote]SetDirectory\
\[CloseCurlyQuote] in \[OpenCurlyQuote]NotebookDirectory\[CloseCurlyQuote] \
nastavi delovno podro\[CHacek]je na ustrezno mapo. "
}], "Text",
 CellChangeTimes->{{3.9851475360099773`*^9, 3.9851476054689465`*^9}, {
  3.98523957599275*^9, 
  3.985239589442259*^9}},ExpressionUUID->"b282c310-1783-44a0-b5cc-\
4217572a8639"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Trenutni imenik: \>\"", ",", 
    RowBox[{"Directory", "[", "]"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SetDirectory", "[", 
   RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9887840412318993`*^9, 3.9887840412318993`*^9}},
